# ── hericarealtor-listing-updater — environment variables ────────────────────
# Copy this file to .env and fill in the values.

# ── Required ──────────────────────────────────────────────────────────────────

# encodedZuid found in Zillow's profile API network requests
ZILLOW_ENCODED_ZUID=

# URL slug of the agent's profile page (e.g. "HericaRealtor")
ZILLOW_PROFILE_SLUG=

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/hericarealtor

# ── Browser ───────────────────────────────────────────────────────────────────

# Set to "true" in Docker/headless environments (launches Xvfb virtual display)
USE_VIRTUAL_DISPLAY=true

# ── Throttle ──────────────────────────────────────────────────────────────────

# Random delay (seconds) between page requests — be polite to Zillow's servers
THROTTLE_MIN=1.5
THROTTLE_MAX=4.0

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
